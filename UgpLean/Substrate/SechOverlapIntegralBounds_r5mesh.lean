private lemma sech5_pt_0_ge : (9089 : ℝ) / 1000000 ≤ ((1 : ℝ) / 110 : ℝ) * sechProd 5 ((1 : ℝ) / 110) := by
  unfold sechProd
  simp only [sech, div_eq_mul_inv]
  have hbin_u : ((1 : ℝ) / 110) ≤ ((19 : ℝ) / 2000) := by norm_num
  have hbin_v : ((1 : ℝ) / 550) ≤ ((1 : ℝ) / 500) := by norm_num
  have hcosh_u : cosh ((1 : ℝ) / 110) ≤ cosh ((19 : ℝ) / 2000) :=
    cosh_mono_Ici (by norm_num) hbin_u
  have hcosh_v : cosh ((1 : ℝ) / 550) ≤ cosh ((1 : ℝ) / 500) :=
    cosh_mono_Ici (by norm_num) hbin_v
  have hc1 := sech_ge_of_cosh_le (by norm_num) (hcosh_u.trans cosh5_u_0_le)
  have hc2 := sech_ge_of_cosh_le (by norm_num) (hcosh_v.trans cosh5_v_0_le)
  have hprod := mul_le_mul hc1 hc2 (by norm_num) (by norm_num)
  field_simp at hprod ⊢
  norm_num at hprod ⊢
  linarith

